# Online Soccer Manager
# OSM migró a login por código de un solo uso (OTP) enviado al correo.
OSM_EMAIL=tu_email@gmail.com
# Substring del remitente OSM para filtrar el correo del código.
# Remitente confirmado: noreply@confirmation.onlinesoccermanager.com
OSM_SENDER=confirmation.onlinesoccermanager.com

# IMAP para leer el código OTP de OSM
# Gmail: habilita IMAP en Ajustes de Gmail y genera un App Password en:
#   Cuenta Google → Seguridad → Verificación en 2 pasos → Contraseñas de aplicación
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=tu_email@gmail.com
IMAP_PASS=xxxx xxxx xxxx xxxx

# Supabase Configuration
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=xxxx_anon_key
