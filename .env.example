# Online Soccer Manager
# OSM migró a login por código de un solo uso (OTP) enviado al correo.
OSM_EMAIL=tu_email@proton.me
# Opcional: substring del remitente OSM para filtrar el correo del código.
# Ajusta solo si el filtro por defecto no detecta los correos de OSM.
# OSM_SENDER=onlinesoccermanager

# Proton Mail Bridge (IMAP local) — credenciales que muestra Bridge con `info`.
# OJO: PROTON_BRIDGE_PASS es la password generada por Bridge, NO la de tu cuenta.
PROTON_BRIDGE_HOST=127.0.0.1
PROTON_BRIDGE_PORT=1143
PROTON_BRIDGE_USER=tu_email@proton.me
PROTON_BRIDGE_PASS=password_generada_por_bridge

# Supabase Configuration
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=xxxx_anon_key
